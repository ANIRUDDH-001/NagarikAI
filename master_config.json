{
  "_comment_scraping": "Controls the web scrapers, what to pull and how hard to hit the servers.",
  "scraping": {
    "target_urls": [
      "https://www.myscheme.gov.in"
    ],
    "rate_limit_seconds": 2,
    "max_retries": 3,
    "auto_retry": true,
    "include_states": ["Delhi", "Maharashtra", "Tamil Nadu", "Uttar Pradesh", "Karnataka"]
  },

  "_comment_cleaning": "Rules for cleaning up raw scraped data before chunking.",
  "cleaning": {
    "min_quality_score": 0.7,
    "required_fields": ["title", "description", "eligibility", "benefits"],
    "drop_fields": ["raw_html", "metadata_crawled_at"],
    "remove_html_tags": true
  },

  "_comment_ingestion": "Settings for chunking text and creating vector embeddings.",
  "ingestion": {
    "chunk_size": 1000,
    "chunk_overlap": 200,
    "embedding_model_name": "all-MiniLM-L6-v2",
    "batch_size": 100
  },

  "_comment_schemes": "Business logic classifying government schemes.",
  "schemes": {
    "tiers": {
      "tier_1": ["National", "Flagship"],
      "tier_2": ["State Level", "Key Initiatives"],
      "tier_3": ["District Level", "Regional"],
      "tier_4": ["Local", "Panchayat"]
    },
    "all_states": ["Andhra Pradesh", "Arunachal Pradesh", "Assam", "Bihar", "Chhattisgarh", "Goa", "Gujarat", "Haryana", "Himachal Pradesh", "Jharkhand", "Karnataka", "Kerala", "Madhya Pradesh", "Maharashtra", "Manipur", "Meghalaya", "Mizoram", "Nagaland", "Odisha", "Punjab", "Rajasthan", "Sikkim", "Tamil Nadu", "Telangana", "Tripura", "Uttar Pradesh", "Uttarakhand", "West Bengal"]
  },

  "_comment_supabase": "Table names in pgvector, configurable to avoid hardcoding in Python.",
  "supabase": {
    "tables": {
      "schemes": "schemes_data",
      "chunks": "schemes_chunks",
      "users": "users",
      "chat_history": "chat_logs"
    }
  },

  "_comment_groq": "LLM inference parameters for generating summaries or agent reasoning.",
  "groq": {
    "model": "mixtral-8x7b-32768",
    "stt_model": "whisper-large-v3",
    "max_tokens": 2048,
    "temperature": 0.1
  }
}
