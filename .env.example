# ==========================================
# 1. APPLICATION & FASTAPI SETTINGS
# ==========================================

# Port for FastAPI server
# Where to get it: Local development choice
# What it controls: Which port the uvicorn server runs on
# Auto-validated: Optional (default: 8000)
PORT=8000

# Debug Mode
# Where to get it: Set to true for local, false for prod
# What it controls: Verbose logging, auto-reload, etc.
# Auto-validated: Optional (default: false)
DEBUG=true

# CORS Origins
# Where to get it: Based on where Next.js is deployed
# What it controls: Which domains can hit this API
# Auto-validated: Optional (default: ["http://localhost:3000"])
CORS_ORIGINS=["http://localhost:3000"]

# ==========================================
# 2. SUPABASE (DATABASE & AUTH)
# ==========================================

# Supabase Project URL
# Where to get it: Supabase Dashboard -> Project Settings -> API
# What it controls: Endpoint for the Supabase REST/GraphQL APIs
# Auto-validated: REQUIRED
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key
# Where to get it: Supabase Dashboard -> Project Settings -> API
# What it controls: Public anonymous access (usually for frontend, but good to have)
# Auto-validated: REQUIRED
SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key
# Where to get it: Supabase Dashboard -> Project Settings -> API
# What it controls: Admin access bypassing RLS policies
# Auto-validated: REQUIRED
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# 3. AI SERVICES (GROQ & SARVAM)
# ==========================================

# Groq API Key
# Where to get it: https://console.groq.com/keys
# What it controls: Access to LLM (Mixtral) and STT (Whisper) models
# Auto-validated: REQUIRED
GROQ_API_KEY=gsk_your_groq_api_key

# Sarvam AI API Key
# Where to get it: https://sarvam.ai/ dashboard
# What it controls: Native language translation/TTS
# Auto-validated: REQUIRED
SARVAM_API_KEY=your_sarvam_api_key

# ==========================================
# 4. PIPELINE SETTINGS
# ==========================================

# Ingestion Batch Size
# Where to get it: Determined dynamically based on memory
# What it controls: How many documents to embed per batch
# Auto-validated: Optional (default: 100)
BATCH_SIZE=100

# Log Level
# Where to get it: Set "INFO", "DEBUG", etc.
# What it controls: Amount of terminal output via the rich library
# Auto-validated: Optional (default: "INFO")
LOG_LEVEL=INFO
